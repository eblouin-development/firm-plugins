# Copy to `.env` on the host and fill in real values. `.env` is gitignored
# and never committed — see references/security/secrets-management.md.
# Every value here is a placeholder/description, never a real secret.

# --- App image (pushed by CI; see README.md "Deploy path") --------------
API_IMAGE=ghcr.io/your-org/your-app-api:latest
# The registry repo (no tag) the deploy scripts (deploy-self-hosted-runner.sh,
# deploy-ssh.sh) pull from and tag with the git SHA at deploy time — set this
# as a CI env var/secret, not necessarily in the host's own .env.
API_IMAGE_REPO=ghcr.io/your-org/your-app-api

# --- App secrets (read from process env — 12-factor, secret_store.py) ---
DATABASE_URL=postgresql+asyncpg://app:changeme@db:5432/app
JWT_SIGNING_KEY=generate-with-openssl-rand-hex-32
SMTP_HOST=smtp.example.com
SMTP_USERNAME=changeme
SMTP_PASSWORD=changeme
EMAIL_FROM=noreply@example.com

# --- Postgres --------------------------------------------------------------
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme-generate-a-real-password
POSTGRES_DB=app

# --- Reverse proxy / TLS ---------------------------------------------------
DOMAIN=app.example.com

# --- Backups -----------------------------------------------------------
BACKUP_CRON=0 3 * * *
# Off-box destination for scripts/backup.sh's rclone push (a second host, or
# an S3-compatible bucket). Leave unset to keep dumps local-only (NOT
# recommended — home-infra.md "Backups": back up off-box).
BACKUP_REMOTE=

# --- Tailscale variant (docker-compose.tailscale.yml only) -----------------
# Ephemeral, reusable, tag:server-scoped auth key — Tailscale admin console
# > Settings > Keys. Disable key expiry on this node once it's joined
# (tailscale.md "Key expiry").
TS_AUTHKEY=
TS_HOSTNAME=compose-host
# 1 to additionally expose this host on the public internet via Funnel
# (client previews, cloud-agent smoke tests) — leave 0/unset for
# tailnet-only Serve, the default.
TS_SERVE_FUNNEL=0
